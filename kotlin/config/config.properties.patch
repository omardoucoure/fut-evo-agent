# ── Twitch (register free app at dev.twitch.tv) ──
twitch.client.id=dtivcvvdf9yy51hwfbaanpvbm5jqiq
twitch.client.secret=qfsxphsmcc3tgbmyzts220j9yncm5u
twitch.game.id=          # FC 26 game ID — find via: GET https://api.twitch.tv/helix/games?name=EA+SPORTS+FC+26
