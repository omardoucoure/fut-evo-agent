# ── Twitter / X (free tier: 500 tweets/month) ──
twitter.bearer.token=YOUR_TWITTER_BEARER_TOKEN
twitter.monthly.quota=500
twitter.quota.file=/Users/mad/.evo-agent-twitter-quota.json
twitter.search.query=from:UTSources OR from:FUTWIZ OR from:FutSheriff OR #FC26meta OR #FC26 meta
