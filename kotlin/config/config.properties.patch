# ── FUTBIN (HTML scraping — be respectful) ──
futbin.delay.ms=3000
futbin.max.players.per.run=30
futbin.reviews.limit=5

# ── FUT.GG (HTML scraping) ──
futgg.delay.ms=3000
futgg.max.players.per.run=25

# ── Priority Players ──
# Top 200 iconic/meta players are defined in PriorityPlayers.kt
# Tier 1 (50 players): scraped every run — Ronaldo, Mbappé, Zidane, Icons...
# Tier 2 (70 players): scraped every 2nd run — meta staples, more Icons
# Tier 3 (80 players): scraped every 3rd run — rising stars, cult heroes
# Priority players are always scraped BEFORE generic top-by-overall fill

# ── Cadence (run source every Nth agent cycle) ──
cadence.twitch=1
cadence.futbin.comments=2
cadence.futgg=3
cadence.futbin.reviews=4
cadence.twitter=6
cadence.reddit.engagement=3

# ── Reddit Engagement (post replies to squad questions) ──
reddit.engagement.enabled=false
reddit.username=
reddit.password=
